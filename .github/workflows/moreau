<!-- Interfaz del Chatbot -->
<div id="ai-launcher">
    <i class="fas fa-robot fa-lg"></i>
</div>

<div id="ai-chatbot">
    <div class="chat-header">
        <span><i class="fas fa-brain"></i> Asistente SEO IA</span>
        <i class="fas fa-times" id="close-chat" style="cursor:pointer"></i>
    </div>
    <div id="chat-body">
        <div class="msg bot">¡Hola! Soy tu consultor SEO virtual. ¿En qué puedo ayudarte hoy? (Prueba preguntando por: "keywords", "backlinks" o "auditoría")</div>
    </div>
    <form class="chat-footer" id="chat-form">
        <input type="text" id="user-input" placeholder="Pregunta algo sobre SEO..." required>
        <button type="submit" style="background:none; border:none; color:var(--primary-color); cursor:pointer">
            <i class="fas fa-paper-plane"></i>
        </button>
    </form>
</div>

<script>
    // Lógica de la Inteligencia Artificial de Marketing
    const launcher = document.getElementById('ai-launcher');
    const chatbot = document.getElementById('ai-chatbot');
    const closeChat = document.getElementById('close-chat');
    const chatForm = document.getElementById('chat-form');
    const chatBody = document.getElementById('chat-body');
    const userInput = document.getElementById('user-input');

    // Base de conocimiento SEO (Simulación de IA)
    const seoKnowledge = {
        keywords: "Las palabras clave son los términos que los usuarios buscan en Google. Te recomiendo usar herramientas como Semrush o Ahrefs para encontrarlas.",
        backlinks: "Los backlinks son enlaces de otros sitios hacia el tuyo. Actúan como 'votos de confianza' y aumentan tu autoridad rápidamente.",
        auditoria: "Una auditoría SEO analiza la velocidad de carga, errores 404 y etiquetas meta. ¿Quieres que revisemos tu sitio?",
        contenido: "El contenido es el rey. Google premia artículos largos, útiles y que respondan la intención de búsqueda del usuario.",
        velocidad: "La velocidad de carga es crucial. Te sugiero optimizar tus imágenes y usar un sistema de caché.",
        hola: "¡Hola! Soy la IA de SEOPRO. Estoy lista para optimizar tu presencia digital.",
        gracias: "¡De nada! Recuerda que el SEO es una carrera de fondo, no de velocidad."
    };

    // Abrir/Cerrar Chat
    launcher.onclick = () => {
        chatbot.classList.add('active');
        launcher.style.display = 'none';
    };

    closeChat.onclick = () => {
        chatbot.classList.remove('active');
        setTimeout(() => launcher.style.display = 'flex', 300);
    };

    // Procesamiento de mensajes
    chatForm.onsubmit = (e) => {
        e.preventDefault();
        const message = userInput.value.toLowerCase();
        
        // Agregar mensaje de usuario
        addMessage(userInput.value, 'user');
        userInput.value = '';

        // "Pensar" y responder
        setTimeout(() => {
            let response = "Interesante pregunta. Como IA de SEO, te sugiero analizar eso en nuestra sección de 'Servicios' o contactar a un experto para un análisis profundo.";
            
            // Buscar coincidencias en conocimiento
            for (let key in seoKnowledge) {
                if (message.includes(key)) {
                    response = seoKnowledge[key];
                    break;
                }
            }
            addMessage(response, 'bot');
        }, 600);
    };

    function addMessage(text, sender) {
        const div = document.createElement('div');
        div.className = `msg ${sender}`;
        div.innerText = text;
        chatBody.appendChild(div);
        chatBody.scrollTop = chatBody.scrollHeight;
    }

    // --- MANTENER SCRIPTS ANTERIORES AQUÍ ---
    // ()
</script>

