        .hero-content p {
            font-size: 1.2rem;
            max-width: 700px;
            margin: 0 auto 2rem;
            opacity: 0.9;
        }

        .btn-main {
            background: var(--primary-color);
            color: white;
            padding: 1rem 2.5rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            transition: transform 0.3s, background 0.3s;
            display: inline-block;
        }

        .btn-main:hover {
            background: var(--accent-color);
            transform: translateY(-3px);
        }

        /* --- Secciones Generales --- */
